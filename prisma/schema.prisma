// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  ADMIN
  CASHIER	
  STOCK_MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  CASH
  GCASH
}

enum SaleStatus {
  PENDING
  PROCESSING
  OUT_FOR_DELIVERY
  COMPLETED
  PARTIALLY_RETURNED
  CANCELLED
  REFUNDED
}

enum LogType {
  STOCK_IN        // delivery received → stock increases
  STOCK_OUT       // sale completed → stock decreases
  ADJUSTMENT      // manual correction (loss report)
  RETURN_IN       // customer return → stock increases
  RETURN_OUT      // return to supplier → stock decreases
}

// NEW: reason categories for loss/adjustment logs
enum LossReason {
  EXPIRED
  DAMAGED
  THEFT
  COUNT_ERROR
  OTHER
}

enum OrderStatus {
  PENDING
  PARTIALLY_RECEIVED
  DELIVERED
  CANCELLED
}

enum CategoryType {
  SOFTDRINKS
  ENERGY_DRINK
  BEER
  JUICE
  WATER
  OTHER
}

// ==========================================
// MODELS
// ==========================================

model Employee {
  id           String     @id
  name         String     @unique
  hashPassword String
  phone        String     @unique
  role         Role
  userStatus   UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  saleRecords   SaleRecord[]
  inventoryLogs InventoryLog[]
}

model Customer {
  id           String     @id
  name         String     @unique
  email        String?    @unique
  address      String?
  phone        String?    @unique
  hashPassword String
  userStatus   UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  saleRecords  SaleRecord[]
  shoppingCart ShoppingCart?
}

model Supplier {
  id           String         @id
  supplierName String
  contactNo    String
  address      String?
  email        String?
  lastOrdered  Int?
  dateChecked  DateTime?
  lastCheckBy  String?
  status       SupplierStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  products   Product[]
  deliveries Delivery[]
}

model Product {
  id            String        @id
  productName   String
  category      CategoryType  @default(SOFTDRINKS)
  size          String?
  barcode       String?       @unique
  price         Float
  stock         Int           @default(0)           // current available stock
  reservedStock Int           @default(0)           // NEW: held by PENDING/PROCESSING orders
  piecesPerCase Int           @default(1)           // NEW: pieces in one case (e.g. 12 for 750ml, 24 for 250ml)
  expiryDate    DateTime?
  image         String?
  status        ProductStatus @default(ACTIVE)
  supplierId    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  supplier          Supplier          @relation(fields: [supplierId], references: [id])
  orderLines        OrderLine[]
  promotionSales    PromotionSale[]
  shoppingCartItems ShoppingCartItem[]
  inventoryLogs     InventoryLog[]
  deliveryItems     DeliveryItem[]
}

model SaleRecord {
  id          String     @id
  employeeId  String?
  customerId  String?
  totalAmount Float
  discount    Float      @default(0)
  status      SaleStatus @default(PENDING)
  saleDate    DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  employee   Employee?   @relation(fields: [employeeId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
  orderLines OrderLine[]
  payment    Payment?
}

model OrderLine {
  id          String   @id @default(cuid())
  saleId      String
  productId   String
  quantity    Int                // ordered in CASES
  returnedQty Int      @default(0) // returned in PIECES (use product.piecesPerCase to convert)
  price       Float
  subtotal    Float
  createdAt   DateTime @default(now())

  saleRecord SaleRecord @relation(fields: [saleId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])
}

model Payment {
  id             String        @id
  saleId         String        @unique
  amount         Float
  method         PaymentMethod @default(CASH)
  amountTendered Float?
  change         Float?
  paidAt         DateTime      @default(now())
  createdAt      DateTime      @default(now())

  saleRecord SaleRecord @relation(fields: [saleId], references: [id])
}

model ShoppingCart {
  id         String   @id
  customerId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer          @relation(fields: [customerId], references: [id])
  items    ShoppingCartItem[]
}

model ShoppingCartItem {
  id             String   @id
  shoppingCartId String
  productId      String
  quantity       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shoppingCart ShoppingCart @relation(fields: [shoppingCartId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
}

model PromotionSale {
  id              String   @id
  productId       String
  promoName       String
  alteredPrice    Float
  discountPercent Float?
  dateEffective   DateTime
  lastDate        DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
}

model InventoryLog {
  seq           Int        @unique @default(autoincrement())
  id            String     @id
  productId     String
  employeeId    String
  quantity      Int        // positive = stock in, negative = stock out
  type          LogType
  reason        String?
  lossReason    LossReason? // NEW: only set when type = ADJUSTMENT (loss report)
  referenceId   String?    // deliveryId or saleId that caused this movement
  referenceType String?    // "DELIVERY" | "SALE" | "MANUAL"
  createdAt     DateTime   @default(now())

  product  Product  @relation(fields: [productId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model Delivery {
  id           String      @id
  supplierId   String
  deliveryDate DateTime
  status       OrderStatus @default(PENDING)
  totalItems   Int         // total ordered items count
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    DeliveryItem[]
}

model DeliveryItem {
  id          String   @id
  deliveryId  String
  productId   String
  orderedQty  Int      // how many were ordered from supplier
  receivedQty Int      @default(0) // how many actually arrived (for partial deliveries)
  returnedQty Int      @default(0) // how many were sent back to supplier
  costPrice   Float
  createdAt   DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}
