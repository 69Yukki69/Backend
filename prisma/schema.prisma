// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  previewFeatures = ["driverAdapters"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  ADMIN
  CASHIER
  STOCK_MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  CASH
  GCASH
}

enum SaleStatus {
  PENDING
  PROCESSING
  OUT_FOR_DELIVERY
  COMPLETED
  PARTIALLY_RETURNED
  CANCELLED
  REFUNDED
}

enum LogType {
  STOCK_IN        // delivery received → stock increases
  STOCK_OUT       // sale completed → stock decreases
  ADJUSTMENT      // manual correction (loss report)
  RETURN_IN       // customer return → stock increases
  RETURN_OUT      // return to supplier → stock decreases
}

enum LossReason {
  EXPIRED
  DAMAGED
  THEFT
  COUNT_ERROR
  OTHER
}

enum ReturnReason {
  WRONG_ITEM_SENT   // resellable → stock +=, RETURN_IN log only
  DAMAGED           // loss → RETURN_IN + ADJUSTMENT (LossReason.DAMAGED)
  EXPIRED           // loss → RETURN_IN + ADJUSTMENT (LossReason.EXPIRED)
  OTHER             // loss → RETURN_IN + ADJUSTMENT (LossReason.OTHER)
}

enum ReturnRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PARTIALLY_RECEIVED
  DELIVERED
  CANCELLED
}

enum CategoryType {
  SOFTDRINKS
  ENERGY_DRINK
  BEER
  JUICE
  WATER
  OTHER
}

// ==========================================
// MODELS
// ==========================================

model Employee {
  id           String     @id
  name         String     @unique
  hashPassword String
  phone        String     @unique
  role         Role
  image        String?    // NEW: Cloudinary URL
  userStatus   UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  saleRecords    SaleRecord[]
  inventoryLogs  InventoryLog[]
  returnRequests ReturnRequest[]
}

model Customer {
  id           String     @id
  name         String     @unique
  email        String?    @unique
  address      String?
  phone        String?    @unique
  hashPassword String
  image        String?    // NEW: Cloudinary URL
  userStatus   UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  saleRecords    SaleRecord[]
  shoppingCart   ShoppingCart?
  returnRequests ReturnRequest[]
}

model Supplier {
  id           String         @id
  supplierName String
  contactNo    String
  address      String?
  email        String?
  lastOrdered  Int?
  dateChecked  DateTime?
  lastCheckBy  String?
  status       SupplierStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  products   Product[]
  deliveries Delivery[]
}

model Product {
  id            String        @id
  productName   String
  category      CategoryType  @default(SOFTDRINKS)
  size          String?
  barcode       String?       @unique
  price         Float
  stock         Int           @default(0)
  reservedStock Int           @default(0)
  piecesPerCase Int           @default(1)
  expiryDate    DateTime?
  image         String?       // Cloudinary URL (already existed)
  status        ProductStatus @default(ACTIVE)
  supplierId    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  supplier          Supplier          @relation(fields: [supplierId], references: [id])
  orderLines        OrderLine[]
  promotionSales    PromotionSale[]
  shoppingCartItems ShoppingCartItem[]
  inventoryLogs     InventoryLog[]
  deliveryItems     DeliveryItem[]
}

model SaleRecord {
  id          String     @id
  employeeId  String?
  customerId  String?
  totalAmount Float
  discount    Float      @default(0)
  status      SaleStatus @default(PENDING)
  saleDate    DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  employee       Employee?       @relation(fields: [employeeId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  orderLines     OrderLine[]
  payment        Payment?
  returnRequests ReturnRequest[]
}

model OrderLine {
  id          String   @id @default(cuid())
  saleId      String
  productId   String
  quantity    Int
  returnedQty Int      @default(0)
  price       Float
  subtotal    Float
  createdAt   DateTime @default(now())

  saleRecord         SaleRecord          @relation(fields: [saleId], references: [id])
  product            Product             @relation(fields: [productId], references: [id])
  returnRequestItems ReturnRequestItem[]
}

model Payment {
  id             String        @id
  saleId         String        @unique
  amount         Float
  method         PaymentMethod @default(CASH)
  amountTendered Float?
  change         Float?
  paidAt         DateTime      @default(now())
  createdAt      DateTime      @default(now())

  saleRecord SaleRecord @relation(fields: [saleId], references: [id])
}

model ShoppingCart {
  id         String   @id
  customerId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer          @relation(fields: [customerId], references: [id])
  items    ShoppingCartItem[]
}

model ShoppingCartItem {
  id             String   @id
  shoppingCartId String
  productId      String
  quantity       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shoppingCart ShoppingCart @relation(fields: [shoppingCartId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
}

model PromotionSale {
  id              String   @id
  productId       String
  promoName       String
  alteredPrice    Float
  discountPercent Float?
  dateEffective   DateTime
  lastDate        DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
}

model InventoryLog {
  seq           Int         @unique @default(autoincrement())
  id            String      @id
  productId     String
  employeeId    String
  quantity      Int
  type          LogType
  reason        String?
  lossReason    LossReason?
  referenceId   String?
  referenceType String?
  createdAt     DateTime    @default(now())

  product  Product  @relation(fields: [productId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])
}

model Delivery {
  id           String      @id
  supplierId   String
  deliveryDate DateTime
  status       OrderStatus @default(PENDING)
  totalItems   Int
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    DeliveryItem[]
}

model DeliveryItem {
  id          String   @id
  deliveryId  String
  productId   String
  orderedQty  Int
  receivedQty Int      @default(0)
  returnedQty Int      @default(0)
  costPrice   Float
  createdAt   DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

// ==========================================
// RETURN REQUEST MODELS
// ==========================================

model ReturnRequest {
  id         String              @id
  saleId     String
  customerId String
  reason     ReturnReason
  status     ReturnRequestStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  saleRecord SaleRecord          @relation(fields: [saleId], references: [id])
  customer   Customer            @relation(fields: [customerId], references: [id])
  reviewer   Employee?           @relation(fields: [reviewedBy], references: [id])
  items      ReturnRequestItem[]
}

model ReturnRequestItem {
  id              String   @id
  returnRequestId String
  orderLineId     String
  returnQty       Int      // in PIECES
  createdAt       DateTime @default(now())

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id])
  orderLine     OrderLine     @relation(fields: [orderLineId], references: [id])
}
